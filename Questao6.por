programa
{
	
	funcao inicio()
	{
		inteiro num1, num2

		escreva("Me informe o valor de primeiro numero: ")
		leia(num1)

		escreva("Me informe o valor do segundo numero: ")
		leia(num2)

		se(num1 > num2){
			escreva("O numero ", num1, " eh o maior")
		}
		senao{
			escreva("o numero ", num2, " eh o maior")
		}
	}
}
